// ============================================================
// VIZ 3: SPARKLINES (interactive grid + detail panel)
// ============================================================
(function(){
  const grid=document.getElementById('sparkGrid');
  const detailEl=document.getElementById('sparkDetail');
  let current=null;

  cancerSites.forEach(site=>{
    const maleM=sparkData[`${site.name}|M|Mortality`]||[];
    const femM=sparkData[`${site.name}|F|Mortality`]||[];
    const primary=site.sex==='M'?maleM:femM;
    const start=primary[0],end=primary[20];
    const pct=start?((end-start)/start)*100:0;
    const isUp=pct>5,isDown=pct<-5;
    const badgeBg=isUp?C.RUST:isDown?C.TEAL:C.SUB;

    const cell=document.createElement('div');cell.className='spark-cell';
    cell.innerHTML=`<div class="spark-header"><div class="spark-name">${site.short}</div><div class="spark-badge" style="background:${badgeBg}">${pct>0?'+':''}${pct.toFixed(0)}%</div></div><div class="spark-note">${site.note}</div>`;

    const W=220,H=58,pad=8;
    const svgEl=d3.select(cell).append('svg').attr('viewBox',`0 0 ${W} ${H}`).attr('width','100%').style('display','block');
    const allV=[...maleM,...femM].filter(v=>v!=null);
    const yMax=d3.max(allV)*1.1||10;
    const xS=d3.scaleLinear().domain([0,20]).range([pad,W-pad]);
    const yS=d3.scaleLinear().domain([0,yMax]).range([H-pad,pad]);
    const lineG=d3.line().defined(v=>v!=null).x((_,i)=>xS(i)).y(d=>yS(d)).curve(d3.curveMonotoneX);

    if(maleM.length)svgEl.append('path').attr('d',lineG(maleM)).attr('fill','none').attr('stroke',C.BLUE).attr('stroke-width',2.2);
    if(femM.length)svgEl.append('path').attr('d',lineG(femM)).attr('fill','none').attr('stroke',C.COPPER).attr('stroke-width',1.7).attr('stroke-dasharray','4,3').attr('opacity',0.85);
    const ref=maleM.length?maleM:femM;
    if(ref.length){
      svgEl.append('text').attr('x',pad).attr('y',yS(ref[0])-4).attr('font-size',9).attr('fill',C.SUB).text(ref[0]);
      svgEl.append('text').attr('x',W-pad).attr('y',yS(ref[20])-4).attr('text-anchor','end').attr('font-size',9).attr('fill',C.SUB).text(ref[20]);
    }

    cell.addEventListener('click',()=>{
      if(current===site.name){current=null;detailEl.innerHTML='';grid.querySelectorAll('.spark-cell').forEach(c=>c.classList.remove('active'));return}
      current=site.name;
      grid.querySelectorAll('.spark-cell').forEach(c=>c.classList.remove('active'));
      cell.classList.add('active');
      renderSparkDetail(site);
    });
    grid.appendChild(cell);
  });

  function renderSparkDetail(site){
    detailEl.innerHTML='';
    const ctx=sparkContext[site.name]||{};
    const maleM=sparkData[`${site.name}|M|Mortality`]||[],femM=sparkData[`${site.name}|F|Mortality`]||[];
    const maleI=sparkData[`${site.name}|M|Incidence`]||[],femI=sparkData[`${site.name}|F|Incidence`]||[];

    const panel=document.createElement('div');panel.className='expand-panel';
    panel.innerHTML=`<div class="expand-title">${site.short} — incidence vs mortality</div><div class="expand-note">${ctx.note||''}</div>`;

    const W=940,H=280,m={t:38,r:92,b:38,l:56};
    const allV=[...maleM,...femM,...maleI,...femI].filter(v=>v!=null);
    const yMax=(d3.max(allV)||10)*1.08;
    const x=d3.scaleLinear().domain([1997,2017]).range([m.l,W-m.r]);
    const y=d3.scaleLinear().domain([0,yMax]).range([H-m.b,m.t]);
    const svg=d3.select(panel).append('svg').attr('width',W).attr('height',H).style('display','block').style('max-width','100%');

    y.ticks(5).forEach(v=>{svg.append('line').attr('x1',m.l).attr('x2',W-m.r).attr('y1',y(v)).attr('y2',y(v)).attr('stroke',C.GRID).attr('stroke-width',1);svg.append('text').attr('x',m.l-8).attr('y',y(v)+4).attr('text-anchor','end').attr('fill',C.SUB).attr('font-size',10).text(v)});
    [1997,2002,2007,2012,2017].forEach(yr=>{svg.append('text').attr('x',x(yr)).attr('y',H-m.b+20).attr('text-anchor','middle').attr('fill',C.SUB).attr('font-size',10).text(yr)});
    svg.append('text').attr('x',m.l).attr('y',m.t-12).attr('fill',C.SUB).attr('font-size',11).text('ASR per 100,000');

    const line=d3.line().defined(v=>v!=null).x((_,i)=>x(1997+i)).y(d=>y(d)).curve(d3.curveMonotoneX);
    const drawL=(vals,stroke,width,dash=null,op=1)=>{if(!vals.length)return;const p=svg.append('path').attr('d',line(vals)).attr('fill','none').attr('stroke',stroke).attr('stroke-width',width).attr('opacity',op);if(dash)p.attr('stroke-dasharray',dash)};
    drawL(maleI,C.BLUE,2.6);drawL(femI,C.COPPER,2.2);
    drawL(maleM,C.BLUE,1.8,'5,4',0.75);drawL(femM,C.COPPER,1.6,'5,4',0.75);

    // Annotations
    if(ctx.type==='annotation'&&ctx.items){ctx.items.forEach(a=>{if(a.y>=1997&&a.y<=2017){svg.append('line').attr('x1',x(a.y)).attr('x2',x(a.y)).attr('y1',m.t).attr('y2',H-m.b).attr('stroke',a.c||C.GOLD).attr('stroke-width',1).attr('stroke-dasharray','4,4').attr('opacity',0.75);svg.append('text').attr('x',x(a.y)+4).attr('y',m.t+10).attr('fill',a.c||C.GOLD).attr('font-size',8.5).attr('font-weight',700).text(a.label)}})}

    // Overlay
    if(ctx.type==='overlay'&&ctx.data){
      const oD=ctx.data,oMax=d3.max(oD.filter(v=>v!=null))||10;
      const oy=d3.scaleLinear().domain([0,oMax*1.15]).range([H-m.b,m.t]);
      const oLine=d3.line().defined(v=>v!=null).x((_,i)=>x(1997+i)).y(d=>oy(d)).curve(d3.curveMonotoneX);
      svg.append('path').attr('d',oLine(oD)).attr('fill','none').attr('stroke',ctx.color||C.GOLD).attr('stroke-width',1.8).attr('stroke-dasharray','2,5').attr('opacity',0.75);
      svg.append('text').attr('x',W-m.r-4).attr('y',m.t+10).attr('text-anchor','end').attr('fill',ctx.color||C.GOLD).attr('font-size',9).attr('font-weight',600).text(ctx.label||'');
    }

    // Legend
    const lg=svg.append('g').attr('transform',`translate(${m.l+6},${m.t-4})`);let lx=0;
    const legLine=(label,stroke,width,dash=null)=>{const g=lg.append('g').attr('transform',`translate(${lx},0)`);const l=g.append('line').attr('x1',0).attr('x2',16).attr('y1',0).attr('y2',0).attr('stroke',stroke).attr('stroke-width',width);if(dash)l.attr('stroke-dasharray',dash);g.append('text').attr('x',22).attr('y',4).attr('fill',C.SUB).attr('font-size',10).text(label);lx+=22+label.length*6.4+18};
    legLine('Incidence',C.FG,2);legLine('Mortality',C.FG,2,'5,4');
    if(maleM.length||maleI.length)legLine('Males',C.BLUE,2.4);
    if(femM.length||femI.length)legLine('Females',C.COPPER,2.1);

    detailEl.appendChild(panel);
  }
})();

