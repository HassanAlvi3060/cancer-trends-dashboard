// VIZ 4: HEATMAP (exact copy from Observable)
// ============================================================
(function(){
  const W=1080,cellW=24,cellH=24,topPad=76,bottomPad=50,leftLabelW=126,changeW=62;
  const gridX=leftLabelW+changeW+30;
  const H=topPad+heatmapFocus.length*cellH+bottomPad;
  const TEAL='#2A7B6F',RUST='#B5634B',MID='#F3E8DA';
  const svg=d3.select('#viz4').append('svg').attr('width',W).attr('height',H).style('background',C.BG);
  svg.append('rect').attr('width',W).attr('height',H).attr('fill',C.BG);
  svg.append('text').attr('x',W/2).attr('y',30).attr('text-anchor','middle').attr('fill',C.FG).attr('font-size',18).attr('font-weight',700).text('Global CRC incidence trends — largest declines vs largest increases');
  svg.append('text').attr('x',leftLabelW).attr('y',56).attr('text-anchor','end').attr('fill',C.SUB).attr('font-size',11).text('Country');
  svg.append('text').attr('x',leftLabelW+changeW).attr('y',56).attr('text-anchor','end').attr('fill',C.SUB).attr('font-size',11).text('% change');
  [1997,2002,2007,2012,2017].forEach(yr=>{svg.append('text').attr('x',gridX+(yr-1997)*cellW+cellW/2).attr('y',56).attr('text-anchor','middle').attr('fill',C.SUB).attr('font-size',10).text(yr)});
  const colorScale=d3.scaleDiverging().domain([-60,0,100]).interpolator(t=>t<0.5?d3.interpolateRgb(TEAL,MID)(t*2):d3.interpolateRgb(MID,RUST)((t-0.5)*2));
  heatmapFocus.forEach((d,i)=>{
    const country=d[0],pct=d[1],vals=d[2],yp=topPad+i*cellH,base=vals[0];
    svg.append('text').attr('x',leftLabelW).attr('y',yp+cellH/2+4).attr('text-anchor','end').attr('fill',C.FG).attr('font-size',11.5).text(country);
    svg.append('text').attr('x',leftLabelW+changeW).attr('y',yp+cellH/2+4).attr('text-anchor','end').attr('fill',pct<0?TEAL:RUST).attr('font-size',10.5).attr('font-weight',700).text(`${pct>0?'+':''}${Math.round(pct)}%`);
    vals.forEach((v,j)=>{const delta=((v-base)/base)*100;svg.append('rect').attr('x',gridX+j*cellW).attr('y',yp+1).attr('width',cellW-1.5).attr('height',cellH-2).attr('rx',2).attr('fill',colorScale(delta))});
  });
  const divI=heatmapFocus.findIndex(d=>d[1]>0);
  if(divI>0)svg.append('line').attr('x1',leftLabelW+8).attr('x2',gridX+21*cellW).attr('y1',topPad+divI*cellH).attr('y2',topPad+divI*cellH).attr('stroke',C.DIV).attr('stroke-width',1.4).attr('stroke-dasharray','4,4');
  const legW=180,legH=10,legX=gridX+(21*cellW-legW)/2,legY=H-26;
  const grad=svg.append('defs').append('linearGradient').attr('id','heatLeg');
  grad.append('stop').attr('offset','0%').attr('stop-color',TEAL);grad.append('stop').attr('offset','50%').attr('stop-color',MID);grad.append('stop').attr('offset','100%').attr('stop-color',RUST);
  svg.append('rect').attr('x',legX).attr('y',legY).attr('width',legW).attr('height',legH).attr('rx',3).attr('fill','url(#heatLeg)');
  svg.append('text').attr('x',legX).attr('y',legY-6).attr('fill',C.SUB).attr('font-size',10).text('Lower than 1997');
  svg.append('text').attr('x',legX+legW).attr('y',legY-6).attr('text-anchor','end').attr('fill',C.SUB).attr('font-size',10).text('Higher than 1997');
})();

