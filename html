  svg.append('line').attr('x1',mid).attr('x2',mid).attr('y1',MT-8).attr('y2',H-MB+4).attr('stroke',C.SUB).attr('stroke-width',1).attr('opacity',0.3);
  [-60,-40,-20,0,20,40,60].forEach(v=>{if(v!==0)svg.append('line').attr('x1',x(v)).attr('x2',x(v)).attr('y1',MT-8).attr('y2',H-MB+4).attr('stroke',C.GRIDL).attr('stroke-width',1);svg.append('text').attr('x',x(v)).attr('y',MT-16).attr('text-anchor','middle').attr('fill',C.SUB).attr('font-size',10).text(`${v>0?'+':''}${v}%`)});
